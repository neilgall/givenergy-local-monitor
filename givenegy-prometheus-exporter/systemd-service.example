[Unit]
Description=GivEnergy Prometheus Exporter
Documentation=https://github.com/yourusername/prometheus-givenergy
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=prometheus
Group=prometheus

# Installation directory
WorkingDirectory=/opt/prometheus-givenergy

# With uv virtual environment:
ExecStart=/opt/prometheus-givenergy/.venv/bin/python3 -m givenergy_exporter

# Environment-based configuration
Environment=INVERTER_HOST=192.168.1.100
Environment=INVERTER_PORT=8899
Environment=POLL_INTERVAL=30
Environment=PROMETHEUS_PORT=9100
Environment=PROMETHEUS_ADDRESS=0.0.0.0

# Alternative: if using pip installation without venv
# ExecStart=/usr/local/bin/givenergy-exporter

# Restart policy
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=givenergy-exporter

# Security
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/var/log

[Install]
WantedBy=multi-user.target
