        {
          "datasource": { "type": "prometheus", "uid": "givenergy-prometheus" },
          "expr": "clamp_min(-givenergy_power_battery_power, 0)",
          "legendFormat": "Battery Charging",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "givenergy-prometheus" },
          "expr": "clamp_min(givenergy_power_grid_power, 0)",
          "legendFormat": "Grid Export",
          "refId": "C"
        }
      ]
    },
    {
      "id": 9,
