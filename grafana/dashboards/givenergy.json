{
  "title": "GivEnergy Solar Monitor",
  "uid": "givenergy-solar",
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d", "90d"]
  },
  "timezone": "browser",
  "tags": ["givenergy", "solar"],
  "annotations": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Power",
      "description": "Instantaneous power readings. Grid: positive = exporting, negative = importing. Battery: positive = discharging, negative = charging.",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 17, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "givenergy-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": false,
            "lineInterpolation": "linear"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Solar" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#F2CC0C", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Grid" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#FF5733", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Consumption" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Battery" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#B877D9", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["last", "max", "min"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "givenergy-prometheus" },
          "expr": "givenergy_power_solar_power",
          "legendFormat": "Solar",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "givenergy-prometheus" },
          "expr": "givenergy_power_grid_power",
          "legendFormat": "Grid",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "givenergy-prometheus" },
          "expr": "givenergy_power_consumption_power",
          "legendFormat": "Consumption",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "givenergy-prometheus" },
          "expr": "givenergy_power_battery_power",
          "legendFormat": "Battery",
          "refId": "D"
        }
      ]
    },
    {
      "id": 2,
      "title": "Battery Level",
      "type": "gauge",
      "gridPos": { "h": 9, "w": 7, "x": 17, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "givenergy-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 20 },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto",
        "text": {}
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "givenergy-prometheus" },
          "expr": "givenergy_power_battery_percent",
          "legendFormat": "Battery %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Current Power Flow",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "panels": []
    },
    {
      "id": 11,
      "title": "Current Power Sources",
      "type": "piechart",
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "givenergy-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "displayLabels": [],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        },
        "pieType": "pie",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "givenergy-prometheus" },
          "expr": "givenergy_power_solar_power",
          "legendFormat": "Solar",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "givenergy-prometheus" },
          "expr": "clamp_min(givenergy_power_battery_power, 0)",
          "legendFormat": "Battery Discharge",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "givenergy-prometheus" },
          "expr": "clamp_min(-givenergy_power_grid_power, 0)",
          "legendFormat": "Grid Import",
          "refId": "C"
        }
      ]
    },
    {
      "id": 12,
      "title": "Current Power Uses",
      "type": "piechart",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "givenergy-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 0
